{
  "name": "dbcooker",
  "displayName": "DBCooker",
  "publisher": "AlthHe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SusieGlitter/DBCooker_vscode.git"
  },
  "description": "DBCooker: A tool for adding built-in functions to databases with automatic modification, diff checking, and chat interaction.",
  "version": "0.0.2",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pythonBridge.start",
        "title": "Start DBCooker Interface"
      },
      {
        "command": "pythonBridge.showLogs",
        "title": "Show DBCooker Logs"
      },
      {
        "command": "cppHelper.confirm",
        "title": "Confirm Changes"
      },
      {
        "command": "cppHelper.discard",
        "title": "Discard Changes"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dbcooker-explorer",
          "title": "DBCooker",
          "icon": "$(rocket)"
        }
      ]
    },
    "views": {
      "dbcooker-explorer": [
        {
          "type": "webview",
          "id": "dbcooker.chatView",
          "name": "DBCooker Chat"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm run compile",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/js-yaml": "^4.0.9",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}