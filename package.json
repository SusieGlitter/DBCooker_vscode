{
  "name": "demo",
  "displayName": "demo",
  "description": "Interact with Python scripts via a React Webview",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.108.1"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pythonBridge.start",
        "title": "Start Python Bridge"
      }
    ],
    "configuration": {
      "title": "Python Bridge",
      "properties": {
        "pythonBridge.apiKey": {
          "type": "string",
          "default": "",
          "description": "API Key to be passed to the Python script configuration."
        },
        "pythonBridge.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "Path to the Python interpreter."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.108.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/js-yaml": "^4.0.9",
    "typescript-eslint": "^8.52.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  }
}